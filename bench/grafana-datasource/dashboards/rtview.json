{
  "title": "Cardano Node (RTView)",
  "uid": "cardano-rtview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    { "id": 1, "type": "row", "title": "Resources",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 } },

    { "id": 2, "type": "timeseries", "title": "Memory — resident",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_Mem_resident_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } } },

    { "id": 3, "type": "timeseries", "title": "CPU usage — process ticks",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_Stat_cputicks_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 4, "type": "timeseries", "title": "RTS threads",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_RTS_threads_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 5, "type": "timeseries", "title": "GC — live bytes in heap",
      "gridPos": { "x": 0, "y": 9, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_RTS_gcLiveBytes_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } } },

    { "id": 6, "type": "timeseries", "title": "GC — major collections",
      "gridPos": { "x": 8, "y": 9, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_RTS_gcMajorNum_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 7, "type": "timeseries", "title": "GC — minor collections",
      "gridPos": { "x": 16, "y": 9, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_RTS_gcMinorNum_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 8, "type": "timeseries", "title": "CPU ticks — GC",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_RTS_gcticks_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 9, "type": "timeseries", "title": "CPU ticks — mutator (app)",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_RTS_mutticks_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },


    { "id": 10, "type": "row", "title": "Blockchain",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 } },

    { "id": 11, "type": "timeseries", "title": "Chain density",
      "gridPos": { "x": 0, "y": 26, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_density_real[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "percentunit" } } },

    { "id": 12, "type": "timeseries", "title": "Slot height",
      "gridPos": { "x": 8, "y": 26, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_slotNum_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 13, "type": "timeseries", "title": "Block height",
      "gridPos": { "x": 16, "y": 26, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_blockNum_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 14, "type": "timeseries", "title": "Slot in epoch",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_slotInEpoch_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 15, "type": "timeseries", "title": "Epoch",
      "gridPos": { "x": 12, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_epoch_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },


    { "id": 16, "type": "row", "title": "Leadership",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 42, "w": 24, "h": 1 } },

    { "id": 17, "type": "timeseries", "title": "Node is leader (counter)",
      "gridPos": { "x": 0, "y": 43, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_Forge_node_is_leader_counter[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 18, "type": "timeseries", "title": "Node not leader (counter)",
      "gridPos": { "x": 8, "y": 43, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_Forge_node_not_leader_counter[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 19, "type": "timeseries", "title": "About to lead (counter)",
      "gridPos": { "x": 16, "y": 43, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_Forge_about_to_lead_counter[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 20, "type": "timeseries", "title": "Blocks forged (counter)",
      "gridPos": { "x": 0, "y": 51, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_Forge_forged_counter[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 21, "type": "timeseries", "title": "Blocks adopted (counter)",
      "gridPos": { "x": 8, "y": 51, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_Forge_adopted_counter[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 22, "type": "timeseries", "title": "Cannot forge (gauge)",
      "gridPos": { "x": 16, "y": 51, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_nodeCannotForge_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },


    { "id": 23, "type": "row", "title": "Transactions",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 59, "w": 24, "h": 1 } },

    { "id": 24, "type": "timeseries", "title": "Txs in mempool",
      "gridPos": { "x": 0, "y": 60, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_txsInMempool_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } },

    { "id": 25, "type": "timeseries", "title": "Mempool size",
      "gridPos": { "x": 8, "y": 60, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_mempoolBytes_int[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } } },

    { "id": 26, "type": "timeseries", "title": "Processed txs (counter)",
      "gridPos": { "x": 16, "y": 60, "w": 8, "h": 8 },
      "datasource": { "type": "iog-cardanotimeseries-datasource", "uid": "cardano-timeseries" },
      "targets": [{ "refId": "A", "queryText": "cardano_node_metrics_txsProcessedNum_counter[$__from; $__to]" }],
      "fieldConfig": { "defaults": { "unit": "short" } } }

  ]
}
